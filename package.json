{
  "name": "drift",
  "private": true,
  "version": "0.1.0",
  "description": "The First Night (codename DRIFT) — mobile-web survival, Phaser 4 + TypeScript.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite/config.dev.mjs",
    "build": "vite build --config vite/config.prod.mjs",
    "preview": "vite preview --config vite/config.prod.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "purity": "node tools/check-purity.mjs",
    "gen:audio": "node tools/gen-audio.mjs",
    "done-checks": "npm run purity && npm run typecheck && npm run test",
    "smoke": "node tools/smoke.mjs"
  },
  "devDependencies": {
    "puppeteer-core": "24.15.0",
    "typescript": "5.7.3",
    "vite": "6.4.3",
    "vitest": "3.2.7"
  },
  "dependencies": {
    "phaser": "4.2.1",
    "terser": "5.39.0"
  }
}
